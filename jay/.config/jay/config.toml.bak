#### Inputs
[[inputs]]
tag = "mice"
match.is-pointer = true
natural-scrolling = true
accel-profile = "Flat"
accel-speed = -0.875


#### Monitors
[[outputs]]
name = "left"
match.connector = "DP-2"
x = 0
y = 0
mode = { width = 2560, height = 1440, refresh-rate = 179.999 }
# tearing.mode = "always"

[[outputs]]
name = "right"
match.connector = "HDMI-A-1"
x = 2560
y = 360
mode = { width = 1920, height = 1080, refresh-rate = 100.000 }


#### Window Rules
[[windows]]
name = "discord"
match.title-regex = "Discord"
action = [ { type = "move-to-workspace", name = "7" }, { type = "move-to-output", workspace = "7", output.name = "right" } ]

[[windows]]
name = "spotify"
match.title-regex = "Spotify"
action = [ { type = "move-to-workspace", name = "10" }, { type = "move-to-output", workspace = "10", output.name = "right" } ]

[[windows]]
name = "waywall"
match.title-regex = "waywall"
action = [ { type = "move-to-workspace", name = "1" }, { type = "move-to-output", workspace = "1", output.name = "left" },
    { type = "set-repeat-rate", rate = { rate = 60, delay = 200} }
]


[[windows]]
name = "default"
action = [
    { type = "set-repeat-rate", rate = { rate = 20, delay = 200 } }
]
