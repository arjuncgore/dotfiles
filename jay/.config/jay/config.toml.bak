#### Keyboard Settings
keymap = """
xkb_keymap {
    xkb_keycodes { include "evdev+aliases(qwerty)" };
    xkb_types    { include "complete"              };
    xkb_compat   { include "complete"              };
    xkb_symbols  { include "pc+us+inet(evdev)+capslock(escape)+ctrl(swap_lalt_lctl)" };
};
"""

repeat-rate = { rate = 20, delay = 200 }


#### Visual Features
workspace-display-order = "sorted"
show-bar = false
show-titles = false

#### Behavior Features
middle-click-paste = false
focus-follows-mouse = true
window-management-key = "Super_L"
pointer-revert-key = "NoSymbol"
# mouse-follows-focus = true

#### Startup Actions
on-graphics-initialized = [
{ type = "exec", exec = { prog = "jay", args = ["run-privileged", "waybar", "-c", "/home/arjungore/.config/waybar/config_jay.jsonc", "-s", "/home/arjungore/.config/waybar/style_jay.css"] } },
{ type = "exec", exec = "mako" },
{ type = "exec", exec = { shell = "swaybg --output DP-2 -i ~/Pictures/wallpapers/jake.png -m fill --output HDMI-A-1 -i ~/Pictures/wallpapers/finn.png -m fill", privileged = true } },

{ type = "show-workspace", name = "1",  output.name = "left"  },
{ type = "show-workspace", name = "2",  output.name = "left"  },
{ type = "show-workspace", name = "3",  output.name = "left"  },
{ type = "show-workspace", name = "4",  output.name = "left"  },
{ type = "show-workspace", name = "5",  output.name = "left"  },

{ type = "show-workspace", name = "6",  output.name = "right" },
{ type = "show-workspace", name = "7",  output.name = "right" },
{ type = "show-workspace", name = "8",  output.name = "right" },
{ type = "show-workspace", name = "9",  output.name = "right" },
{ type = "show-workspace", name = "10", output.name = "right" }

]

#### Idle Actions
idle = {
    minutes = 10,
    grace-period = { seconds = 10 },
}

on-idle = {
    type = "exec",
    exec = {
        prog = "swaylock",
        privileged = true,
    },
}


#### Theme
[theme]
# border-width = 2
# border-color = "#00FFFF"

# bar-bg-color = "#1f1d11"
# bar-status-text-color = "#e6c99d"
# captured-focused-title-bg-color = "#b97d3e"
# captured-unfocused-title-bg-color = "#1f1d11"
# focused-inactive-title-bg-color = "#1f1d11"
# focused-inactive-title-text-color = "#e6c99d"
# focused-title-bg-color = "#b97d3e"
# focused-title-text-color = "#1f1d11"
# separator-color = "#1f1d11"
# unfocused-title-bg-color = "#1f1d11"
# unfocused-title-text-color = "#e6c99d"
# font = "cozette 11"


#### Shortcuts
[shortcuts]

## Launching Apps
logo-Return             = { type = "exec", exec = { prog = "kitty", privileged = true} }
logo-shift-Return       = { type = "exec", exec = "kitty" }
logo-p                  = { type = "exec", exec = { prog = "wofi", args = ["--show", "drun"], privileged = true }}
logo-b                  = { type = "exec", exec = "zen-browser" }
logo-shift-b            = { type = "exec", exec = "google-chrome-stable" }
logo-f                  = { type = "exec", exec = "thunar" }
logo-c                  = { type = "exec", exec = "code" }
logo-l                  = "open-control-center"
logo-u                  = "warp-mouse-to-focus"

# logo-s                  = { type = "exec", exec = "spotify" }
logo-s                  = [
{ type = "show-workspace", name = "10", output.name = "right" },
{ type = "exec", exec = "spotify" }
]

# logo-d                  = { type = "exec", exec = "discord" }
logo-d                  = [
{ type = "show-workspace", name = "7", output.name = "right" },
{ type = "exec", exec = "discord" }
]


## System Actions
logo-q                  = "close"
logo-shift-r            = "reload-config-toml"
logo-shift-e            = { type = "exec", exec = { prog = "bash", args = ["-lc", "~/.config/jay/exit-menu.sh"] } }
logo-shift-s            = { type = "exec", exec = { prog = "bash", args = ["-lc", "~/.config/jay/shutdown-menu.sh"] } }

logo-shift-p            = { type = "exec", exec = { prog = "bash", args = ["-lc", 'wayfreeze & PID=$!; sleep 0.1; grim -g "$(slurp)" - | wl-copy; kill "$PID" 2>/dev/null'], privileged = true } }
logo-shift-o            = { type = "exec", exec = { prog = "bash", args = ["-lc", 'wayfreeze & PID=$!; sleep 0.1; grim -g "$(slurp)" - | swappy -f -; kill "$PID" 2>/dev/null'], privileged = true } }

logo-F10                = { type = "exec", exec = { prog = "playerctl", args = ["-p", "spotify", "previous"], privileged = true }}
logo-F11                = { type = "exec", exec = { prog = "playerctl", args = ["-p", "spotify", "play-pause"], privileged = true }}
logo-F12                = { type = "exec", exec = { prog = "playerctl", args = ["-p", "spotify", "next"], privileged = true }}

## Window Movement/Management
logo-Left               = [
    "focus-left",
    "warp-mouse-to-focus"
]
logo-Right              = [
    "focus-right",
    "warp-mouse-to-focus"
]
logo-Up                 = [
    "focus-up",
    "warp-mouse-to-focus"
]
logo-Down               = [
    "focus-down",
    "warp-mouse-to-focus"
]

logo-shift-Left         = [
    "move-left",
    "warp-mouse-to-focus"
]
logo-shift-Right        = [
    "move-right",
    "warp-mouse-to-focus"
]
logo-shift-Up           = [
    "move-up",
    "warp-mouse-to-focus"
]
logo-shift-Down         = [
    "move-down",
    # "warp-mouse-to-focus"
]

logo-ctrl-h             = "split-horizontal"
logo-ctrl-v             = "split-vertical"
logo-e                  = "toggle-split"
logo-shift-f            = "toggle-fullscreen"
logo-shift-space        = "toggle-floating"

## Workspaces
logo-1          = [ 
    { type = "show-workspace", name = "1",  output.name = "left"  },
    "warp-mouse-to-focus"
]
logo-2          = [ 
    { type = "show-workspace", name = "2",  output.name = "left"  },
    "warp-mouse-to-focus"
]
logo-3          = [ 
    { type = "show-workspace", name = "3",  output.name = "left"  },
    "warp-mouse-to-focus"
